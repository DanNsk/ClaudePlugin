{
  "name": "Pyright LSP",
  "version": "1.0.0",
  "description": "Python language server using Pyright",
  "attribution": "Based on Piebald-AI/claude-code-lsps",
  "lsp": {
    "languages": ["python"],
    "filePatterns": ["*.py", "*.pyi"],
    "command": "cmd",
    "args": ["/c", "pyright-langserver", "--stdio"]
  }
}
