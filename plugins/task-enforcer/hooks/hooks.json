{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/scripts/session_start.py\" --session",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[pre-stop] Before finishing, verify where applicable: build passes, tests added/updated, docs reflect changes. Skip items that do not apply.\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/scripts/session_start.py\" --prompt",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
