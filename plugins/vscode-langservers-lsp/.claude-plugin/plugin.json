{
  "name": "VS Code Language Servers",
  "version": "1.0.0",
  "description": "HTML, CSS, JSON, and Markdown language servers from VS Code",
  "attribution": "Based on Piebald-AI/claude-code-lsps",
  "lsp": [
    {
      "languages": ["html"],
      "filePatterns": ["*.html", "*.htm"],
      "command": "cmd",
      "args": ["/c", "vscode-html-language-server", "--stdio"]
    },
    {
      "languages": ["css", "scss", "less"],
      "filePatterns": ["*.css", "*.scss", "*.less"],
      "command": "cmd",
      "args": ["/c", "vscode-css-language-server", "--stdio"]
    },
    {
      "languages": ["json", "jsonc"],
      "filePatterns": ["*.json", "*.jsonc"],
      "command": "cmd",
      "args": ["/c", "vscode-json-language-server", "--stdio"]
    },
    {
      "languages": ["markdown"],
      "filePatterns": ["*.md", "*.markdown"],
      "command": "cmd",
      "args": ["/c", "vscode-markdown-language-server", "--stdio"]
    }
  ]
}
