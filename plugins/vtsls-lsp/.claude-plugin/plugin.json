{
  "name": "TypeScript LSP",
  "version": "1.0.0",
  "description": "TypeScript/JavaScript language server using vtsls",
  "attribution": "Based on Piebald-AI/claude-code-lsps",
  "lsp": {
    "languages": ["typescript", "javascript", "typescriptreact", "javascriptreact"],
    "filePatterns": ["*.ts", "*.tsx", "*.js", "*.jsx", "*.mts", "*.cts", "*.mjs", "*.cjs"],
    "command": "cmd",
    "args": ["/c", "vtsls", "--stdio"]
  }
}
